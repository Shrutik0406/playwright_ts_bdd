{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "steps/**/*.ts",
    "pages/**/*.ts",
    "feature/**/*.feature",
    "data/**/*.json"
  ]
}